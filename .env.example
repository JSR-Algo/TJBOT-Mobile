# TBOT Mobile — Local Development Environment
# Copy to .env and fill in your Mac's local IP address
#
# To find your IP:
#   macOS: ipconfig getifaddr en0
#   Linux: hostname -I | awk '{print $1}'
#
# Then replace 192.168.x.x below with your actual IP

# Backend API (tbot-backend on port 3000)
TBOT_API_URL=http://192.168.x.x:3000

# AI Service (tbot-ai-services on port 3001)
TBOT_AI_URL=http://192.168.x.x:3001/api/ai

# Observability (optional)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Voice debug — set to 'true' to force iOS to use the native VoiceMicModule
# instead of the RNLAS fallback. Used for diagnosing the on-device "mic
# auto-turns-off" issue. Default off. See
# docs/qa/ad-hoc/2026-04-23-ios-mic-auto-off-diagnostics.md.
EXPO_PUBLIC_VOICE_FORCE_NATIVE_IOS=

# Legacy (kept for compatibility)
API_URL=http://192.168.x.x:3000/v1
WS_URL=ws://192.168.x.x:3000
