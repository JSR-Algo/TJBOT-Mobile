{
  "name": "tbot-mobile",
  "version": "1.0.1",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "test": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "e2e:mobile": "node scripts/e2e-mobile.js",
    "e2e:mobile:local": "TBOT_API_URL=http://localhost:3000 node scripts/e2e-mobile.js",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug",
    "detox:build:android": "detox build --configuration android.emu.debug",
    "detox:test:android": "detox test --configuration android.emu.debug"
  },
  "dependencies": {
    "@google/genai": "^1.49.0",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@react-navigation/stack": "^7.8.9",
    "@sentry/react-native": "^7.5.0",
    "axios": "^1.7.9",
    "expo": "^55.0.11",
    "expo-audio": "~55.0.11",
    "expo-device": "~55.0.12",
    "expo-haptics": "~55.0.11",
    "expo-notifications": "~55.0.16",
    "expo-secure-store": "~55.0.11",
    "lucide-react-native": "^1.8.0",
    "posthog-react-native": "^3.6.0",
    "react": "19.2.0",
    "react-native": "0.83.4",
    "react-native-ble-plx": "^3.5.1",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-live-audio-stream": "^1.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/metro-config": "^0.84.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.2.10",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "detox": "^20.29.3",
    "detox-cli": "^20.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.0",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "preset": "react-native",
        "setupFiles": [
          "<rootDir>/tests/setup.ts"
        ],
        "moduleNameMapper": {
          "expo-secure-store": "<rootDir>/tests/__mocks__/expo-secure-store.ts",
          "expo-av": "<rootDir>/tests/__mocks__/expo-av.ts",
          "expo-haptics": "<rootDir>/tests/__mocks__/expo-haptics.ts",
          "expo-audio": "<rootDir>/tests/__mocks__/expo-audio.ts",
          "expo-notifications": "<rootDir>/tests/__mocks__/expo-notifications.ts",
          "expo-device": "<rootDir>/tests/__mocks__/expo-device.ts",
          "react-native-ble-plx": "<rootDir>/tests/__mocks__/react-native-ble-plx.ts"
        },
        "testMatch": [
          "<rootDir>/tests/**/*.test.{ts,tsx}"
        ],
        "testPathIgnorePatterns": [
          "<rootDir>/tests/integration/"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-screens|react-native-safe-area-context|react-native-gesture-handler|expo-secure-store|expo)/)"
        ]
      },
      {
        "displayName": "integration",
        "preset": "react-native",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/tests/integration/**/*.test.{ts,tsx}"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-screens|react-native-safe-area-context|react-native-gesture-handler|expo-secure-store|expo)/)"
        ],
        "globalSetup": "<rootDir>/tests/integration/__setup__/global-setup.ts",
        "globalTeardown": "<rootDir>/tests/integration/__setup__/global-teardown.ts"
      }
    ]
  }
}
